<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="006-create-ordered-product" author="Ivan Aksenov">
        <createTable tableName="ordered_product">
            <column name="product_id" type="uuid">
                <constraints primaryKey="true" foreignKeyName="fk_ordered_product_customer_id" nullable="false" references="product(id)"/>
            </column>
            <column name="order_id" type="uuid">
                <constraints primaryKey="true" foreignKeyName="fk_ordered_product_order_id" nullable="false" references="orders(id)"/>
            </column>
            <column name="price" type="numeric(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>